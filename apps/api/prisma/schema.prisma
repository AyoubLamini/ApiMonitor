generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int   @id @default(autoincrement())
  email     String   @unique
  password  String
  username  String   @unique
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  apiKeys ApiKey[] // Add this line to define the inverse relation
}

model ApiKey {
  id        Int   @id @default(autoincrement())
  key       String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  USER
}